{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thellmreport.com/schemas/snapshots/pricing-api/v2.json",
  "title": "pricing-API canonical snapshot (v2)",
  "description": "design.md 1.2.3: {prices: [{model_ref, dimension{...}, value}]} — dimension as in the price-structure sub-schema (design.md 1.2.2).",
  "type": "object",
  "required": [
    "prices"
  ],
  "properties": {
    "prices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "model_ref",
          "dimension",
          "value"
        ],
        "properties": {
          "model_ref": {
            "type": "string",
            "description": "Provider-native model reference as it appears in the pricing source"
          },
          "dimension": {
            "$ref": "https://thellmreport.com/schemas/data/price-structure/v2.json#/$defs/dimension"
          },
          "value": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
