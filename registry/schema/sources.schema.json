{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thellmreport.com/schemas/registry/sources.schema.json",
  "title": "The LLM Report source registry (registry/sources.json)",
  "description": "Normative machine-readable allowlist per design.md §1.3. Collectors may fetch ONLY URLs present in this registry; the exclusion list lives in the same file (records with excluded=true, match_scope=host); CI fails any collector referencing an unregistered URL. Per-host conditions encode the binding decisions of compliance/tou-sweep-2026-07/00-sweep-summary.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "updated",
    "tou_sweep",
    "fetch_defaults",
    "sentinels",
    "sources"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "registry_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": { "type": "string", "format": "date" },
    "tou_sweep": {
      "type": "string",
      "pattern": "^compliance/tou-sweep-[0-9]{4}-[0-9]{2}/"
    },
    "fetch_defaults": {
      "type": "object",
      "required": [
        "user_agent",
        "conditional_get",
        "max_polls_per_hour_per_page",
        "robots_recheck_default",
        "global_sentinels"
      ],
      "properties": {
        "user_agent": {
          "const": "TheLLMReportBot/1.0 (+https://thellmreport.com/bot)"
        },
        "conditional_get": { "const": true },
        "max_polls_per_hour_per_page": { "const": 1 },
        "robots_recheck_default": { "$ref": "#/$defs/robotsRecheck" },
        "global_sentinels": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "sentinels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/sentinel" }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "robotsRecheck": {
      "enum": ["every-cycle", "daily", "weekly"]
    },
    "sentinel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "trigger", "action", "cadence"],
      "properties": {
        "scope": { "type": "string" },
        "watch": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "fetch_via": { "type": "string" },
        "trigger": { "type": "string" },
        "action": { "type": "string" },
        "cadence": { "enum": ["every-fetch", "every-cycle", "weekly"] }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "url",
        "method",
        "auth",
        "class",
        "lineage",
        "cadence",
        "failover",
        "entitlement_caveat",
        "tou_ref",
        "excluded"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "method": { "enum": ["GET", "POST", null] },
        "auth": {
          "type": "string",
          "pattern": "^(none|sigv4|header:[A-Za-z0-9-]+)$"
        },
        "class": {
          "enum": [
            "official-api",
            "provider-docs",
            "third-party-aggregator",
            "own-probe",
            "statuspage",
            "policy-page"
          ]
        },
        "lineage": {
          "enum": ["provider-primary", "third-party-aggregator", "own-probe"]
        },
        "cadence": { "enum": ["hourly", "daily", "weekly", null] },
        "failover": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "entitlement_caveat": { "type": ["string", "null"] },
        "tou_ref": {
          "type": ["string", "null"],
          "pattern": "^compliance/tou-sweep-[0-9]{4}-[0-9]{2}/[a-z0-9-]+\\.md$"
        },
        "excluded": { "type": "boolean" },
        "exclusion_reason": { "type": "string", "minLength": 1 },
        "conditions": { "$ref": "#/$defs/conditions" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "excluded": { "const": true } },
            "required": ["excluded"]
          },
          "then": {
            "required": ["exclusion_reason", "conditions"],
            "properties": {
              "method": { "const": null },
              "cadence": { "const": null },
              "failover": { "const": null },
              "conditions": {
                "required": ["match_scope"],
                "properties": { "match_scope": { "const": "host" } }
              }
            }
          },
          "else": {
            "properties": {
              "method": { "enum": ["GET", "POST"] },
              "cadence": { "enum": ["hourly", "daily", "weekly"] }
            },
            "not": { "required": ["exclusion_reason"] }
          }
        },
        {
          "if": {
            "properties": { "class": { "const": "policy-page" } },
            "required": ["class"]
          },
          "then": {
            "properties": {
              "cadence": { "const": "weekly" },
              "conditions": {
                "required": ["robots_recheck", "wayback_only"],
                "properties": {
                  "robots_recheck": { "const": "weekly" }
                }
              }
            },
            "required": ["conditions"]
          }
        },
        {
          "if": {
            "properties": {
              "url": { "pattern": "^https://docs\\.aws\\.amazon\\.com/" },
              "excluded": { "const": false }
            },
            "required": ["url", "excluded"]
          },
          "then": {
            "required": ["conditions"],
            "properties": {
              "conditions": {
                "required": ["crawl_delay_s", "attribution", "sentinels"],
                "properties": {
                  "crawl_delay_s": { "minimum": 5 },
                  "attribution": { "const": "cc-by-sa-4.0" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "url": { "pattern": "^https://(docs\\.x\\.ai|x\\.ai)/" }
            },
            "required": ["url"]
          },
          "then": {
            "required": ["conditions"],
            "properties": {
              "conditions": { "required": ["content_signals"] }
            }
          }
        },
        {
          "if": {
            "properties": { "excluded": { "const": false } },
            "required": ["excluded"]
          },
          "then": {
            "required": ["conditions"],
            "properties": {
              "conditions": { "required": ["robots_recheck", "attribution"] }
            }
          }
        }
      ]
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "robots_recheck": { "$ref": "#/$defs/robotsRecheck" },
        "crawl_delay_s": { "type": "number", "minimum": 0 },
        "attribution": {
          "enum": ["cc-by-4.0", "cc-by-sa-4.0", "apache-2.0", "none"]
        },
        "content_signals": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "ai-train": { "enum": ["yes", "no"] },
            "ai-input": { "enum": ["yes", "no"] }
          }
        },
        "wayback_only": { "type": "boolean" },
        "deterministic_only": { "type": "boolean" },
        "never_authenticate": { "type": "boolean" },
        "skip_paths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "path_scope": { "type": "string" },
        "match_scope": { "enum": ["url", "host"] },
        "mirror_primary": { "type": "string", "format": "uri" },
        "canonical_page": { "type": "string", "format": "uri" },
        "fetch_scope": { "enum": ["content", "liveness-parity-only"] },
        "mechanism": { "type": "string" },
        "extraction_rule_id": { "type": "string" },
        "corroboration_only": { "type": "boolean" },
        "sentinels": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "notes": { "type": "string" }
      }
    }
  }
}
